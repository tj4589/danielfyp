# Environment variables for CX Intelligence System
# Fallback local MongoDB (adjust if you have a different setup)
LOCAL_MONGODB_URI=mongodb://127.0.0.1:27017/feedbackDB
# If you have an Atlas URI, uncomment the line below and replace with your own
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/feedbackDB?retryWrites=true&w=majority
# Optional: custom port (default 3000)
# PORT=3000
PORT=3001
